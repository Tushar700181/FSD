{
  "name": "OneCampus Node.js & MongoDB",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/mongodb/devcontainer-features/mongodb-community:1": {}
  },
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "OneCampus Web App",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "npm install",
  "postStartCommand": "npm run dev",
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md", "backend/server.js"]
    }
  }
}
