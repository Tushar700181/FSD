{
  "name": "OneCampus Node.js & MongoDB",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/FSD",
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "OneCampus Web App",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "npm install",
  "postStartCommand": "npm run dev",
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md", "backend/server.js"]
    }
  }
}
